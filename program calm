# ------------------ TIMER ------------------
def create_timer(entry):
    time_left = 6 * 60 + 7

    def update():
        nonlocal time_left
        global timers_expired

        if time_left <= 0:
            entry.delete(0, tk.END)
            entry.insert(0, "I forgot.")
            entry.config(bg="red")
            timers_expired = True
            return

        time_left -= 1
        root.after(1000, update)

    update()

# ------------------ VALIDATION COLOR ------------------
def mark_valid(entry):
    entry.config(bg="white")

def mark_invalid(entry):
    entry.config(bg="red")

# ------------------ USERNAME ------------------
username_stage = 0

def validate_username():
    global username_stage
    name = username_entry.get()

    if username_stage == 0:
        if len(name) >= 9:
            username_stage += 1
            mark_valid(username_entry)
            messagebox.showinfo("OK", "Sad mora sadržavati broj.")
        else:
            mark_invalid(username_entry)
    elif username_stage == 1:
        if any(c.isdigit() for c in name):
            username_stage += 1
            mark_valid(username_entry)
            messagebox.showinfo("OK", "Sad mora sadržavati znak.")
        else:
            mark_invalid(username_entry)
    elif username_stage == 2:
        if any(not c.isalnum() for c in name):
            username_stage += 1
            mark_valid(username_entry)
            messagebox.showinfo("OK", "Sad mora imati veliko slovo.")
        else:
            mark_invalid(username_entry)
    elif username_stage == 3:
        if any(c.isupper() for c in name):
            username_stage += 1
            mark_valid(username_entry)
            messagebox.showinfo("OK", "Sad suma znamenki mora biti 25.")
        else:
            mark_invalid(username_entry)
    elif username_stage == 4:
        suma = sum(int(c) for c in name if c.isdigit())
        if suma == 25:
            mark_valid(username_entry)
            messagebox.showinfo("OK", "Korisničko ime prihvaćeno!")
        else:
            mark_invalid(username_entry)

