# ------------------ EMAIL ------------------
def validate_email():
    if email_entry.get() != "ragebaited@gmail.com":
        mark_invalid(email_entry)
    else:
        mark_valid(email_entry)

# ------------------ PASSWORD ------------------
def validate_password():
    if len(password_entry.get()) != 67:
        mark_invalid(password_entry)
    else:
        mark_valid(password_entry)

# ------------------ ESSAY ------------------
def validate_essay():
    if len(essay_text.get("1.0", tk.END).split()) < 150:
        essay_text.config(bg="red")
        return False
    essay_text.config(bg="white")
    return True

# ------------------ CARD ------------------
def validate_card():
    card = card_entry.get()
    if len(card) != 15 or not card.isdigit():
        mark_invalid(card_entry)
    else:
        mark_valid(card_entry)

# ------------------ MONEY ------------------
def validate_money():
    try:
        money = float(money_entry.get())
        if money < 50000:
            mark_invalid(money_entry)
        else:
            mark_valid(money_entry)
    except:
        mark_invalid(money_entry)

# ------------------ FINAL VALIDATION ------------------
def all_valid():
    return (
        email_entry.get() == "ragebaited@gmail.com" and
        len(password_entry.get()) == 67 and
        len(card_entry.get()) == 15 and
        card_entry.get().isdigit() and
        validate_essay()
    )

# ------------------ CHAOS WINDOWS ------------------
def chaos():
    global timers_expired

    if timers_expired:
        messagebox.showerror("Greška", "Vrijeme je isteklo! Podaci više nisu valjani.")
        return

    if not all_valid():
        messagebox.showerror("Greška", "Nisu svi podaci ispravni!")
        return

    win = tk.Toplevel(root)
    win.geometry("300x150")

    x = random.randint(0, root.winfo_screenwidth() - 300)
    y = random.randint(0, root.winfo_screenheight() - 150)
    win.geometry(f"+{x}+{y}")

    tk.Label(win, text="Jesi li siguran?").pack()

    def next_window():
        global timers_expired
        if timers_expired:
            for w in root.winfo_children():
                if isinstance(w, tk.Toplevel):
                    w.destroy()
            messagebox.showerror("Greška", "Vrijeme je isteklo! Povratak na obrazac.")
            return
        chaos()

    tk.Button(win, text="Siguran/na sam.", command=next_window).pack()

    hidden = tk.Button(win, text=".", bg=win.cget("bg"), fg=win.cget("bg"),
                       command=root.destroy)
    hidden.place(x=1, y=1)

