# -------------------  KORISNIČKO IME -------------------

ime_nivo=0

def provjera_imena():
    global ime_nivo
    ime=ime_unos.get()
    if ime_nivo==0:
        if len(ime)>= 9:
            ime_nivo+=1
            oznaci_tocno(ime_unos)
            messagebox.showinfo("Nadodajte", "Sad mora sadržavati broj.")
        else:
            oznaci_netocno(ime_unos)
    elif ime_nivo==1:
        if any(c.isdigit() for c in ime):
            ime_nivo+=1
            oznaci_tocno(ime_unos)
            messagebox.showinfo("Nadodajte", "Sad mora sadržavati znak.")
        else:
            oznaci_netocno(ime_unos)
    elif ime_nivo==2:
        if any(not c.isalnum() for c in ime):
            ime_nivo+=1
            oznaci_tocno(ime_unos)
            messagebox.showinfo("Nadodajte", "Sad mora imati veliko slovo.")
        else:
            oznaci_netocno(ime_unos)
    elif ime_nivo==3:
        if any(c.isupper() for c in ime):
            ime_nivo+=1
            oznaci_tocno(ime_unos)
            messagebox.showinfo("Nadodajte", "Sad zbroj znamenki mora biti 25.")
        else:
            oznaci_netocno(ime_unos)
    elif ime_nivo==4:
        suma=sum(int(c) for c in ime if c.isdigit())
        if suma==25:
            oznaci_tocno(ime_unos)
            messagebox.showinfo("Uspjeh!", "Korisničko ime prihvaćeno!")
        else:
            oznaci_netocno(ime_unos)

