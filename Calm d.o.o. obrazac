# ------------------- BROJAČ-------------------

def brojac(brojac_unos):
    preostalo_vrijeme=6 * 60 + 7

    def update():
        nonlocal preostalo_vrijeme
        global brojac_zavrsio
        if preostalo_vrijeme<=0:
            brojac_unos.config(state="normal")
            brojac_unos.delete(0, tk.END)
            brojac_unos.insert(0, "Vrijeme isteklo!")
            brojac_unos.config(bg="red")
            for entry in svi_unosi:
                entry.config(state="normal")
                entry.delete(0, tk.END)
                entry.insert(0, "I forgot.")
                entry.config(bg="red")
            brojac_zavrsio=True
            return

        minute=preostalo_vrijeme // 60
        sekunde=preostalo_vrijeme % 60
        brojac_unos.delete(0, tk.END)
        brojac_unos.insert(0, f"{minute:02}:{sekunde:02}")
        preostalo_vrijeme-=1
        glavni.after(1000, update)
    update()

